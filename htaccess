<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to dotfiles (.env, .git, etc.)
    RewriteRule (^|/)\.(?!htaccess) - [F,L]

    # Block access to sensitive project files
    RewriteRule ^(composer\.(json|lock)|schema\.sql|README\.md|htaccess)$ - [F,L]

    # Block access to application directories
    RewriteRule ^(src|views|storage|migrations|vendor)(/|$) - [F,L]

    # Forward to public/ only if not already there
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>